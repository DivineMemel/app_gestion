# =================================================================
# Supabase — Project Settings → API
# Crée un projet Supabase dédié au salon (ne réutilise pas celui de Pilote)
# Lance les migrations dans supabase/migrations/ via le SQL Editor
# =================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Pour les server actions / route handlers qui ont besoin de bypasser RLS
# (réservation publique, par exemple). NE PAS exposer côté client.
SUPABASE_SERVICE_ROLE=eyJ...

# =================================================================
# Auth admin — protège /admin/*
# ADMIN_PASSWORD : ce que la salonnière tape pour se connecter
# ADMIN_TOKEN    : valeur stockée dans le cookie httpOnly (random ≥ 32 chars)
# =================================================================
ADMIN_PASSWORD=change-me
ADMIN_TOKEN=replace-with-a-long-random-string-32chars-min
